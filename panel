<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ENAMI EP - Administración de Proyectos</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        .animate-fade-in { animation: fadeIn 0.3s ease-in; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
    </style>
</head>
<body class="bg-[#f3f4f6] font-sans text-slate-900">
    <div id="app" class="min-h-screen p-4 md:p-8">
        
        <!-- Header -->
        <div class="max-w-[1600px] mx-auto mb-8">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
                <div class="flex items-center gap-4">
                    <h1 class="text-3xl font-black italic tracking-tighter text-slate-800 uppercase leading-none">ENAMI EP</h1>
                    <div class="h-8 w-px bg-slate-300 mx-2"></div>
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-[0.3em]">Gestión Administrativa</p>
                </div>
                <div class="flex gap-3">
                    <label class="cursor-pointer bg-white border border-slate-300 px-5 py-2.5 rounded-2xl text-[10px] font-black uppercase tracking-widest flex items-center gap-2 hover:bg-slate-50 transition-all shadow-sm">
                        <i data-lucide="upload" class="w-4 h-4 text-blue-600"></i> Cargar Mapa Base
                        <input type="file" id="mapUpload" class="hidden" accept="image/*">
                    </label>
                    <button id="newProjectBtn" class="bg-[#1e293b] text-white px-6 py-2.5 rounded-2xl text-[10px] font-black uppercase tracking-widest shadow-lg hover:bg-slate-800 transition-all">
                        Nuevo Proyecto
                    </button>
                </div>
            </div>

            <!-- KPI Único -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-[2rem] shadow-sm flex items-center justify-between border border-white">
                    <div>
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-1">Total Concesiones Activas</p>
                        <p id="kpiConcessions" class="text-4xl font-black text-slate-800">0</p>
                    </div>
                    <div class="bg-blue-50 p-4 rounded-2xl text-blue-500"><i data-lucide="file-text"></i></div>
                </div>
            </div>
        </div>

        <main class="max-w-[1600px] mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            
            <!-- Zona de Mapa -->
            <div class="lg:col-span-8">
                <div id="mapContainer" class="relative aspect-[16/11] rounded-[3rem] border-8 border-white shadow-2xl overflow-hidden bg-slate-100 flex items-center justify-center transition-all duration-500">
                    <div id="mapPlaceholder" class="text-center text-slate-300 p-10">
                        <i data-lucide="globe" class="w-20 h-20 mx-auto mb-4 opacity-10"></i>
                        <p class="text-xs font-bold uppercase tracking-widest italic text-center">Ubica el proyecto haciendo clic en el mapa</p>
                    </div>
                    <img id="baseMapImg" class="hidden w-full h-full object-contain pointer-events-none select-none p-4" alt="Mapa">
                    <div id="pinsOverlay" class="absolute inset-0 pointer-events-none"></div>
                    <div id="clickLayer" class="absolute inset-0 cursor-crosshair hidden z-10"></div>
                </div>
            </div>

            <!-- Panel de Control -->
            <div class="lg:col-span-4 space-y-6">
                
                <!-- Formulario -->
                <div id="formSection" class="hidden bg-white p-8 rounded-[3rem] shadow-2xl border-t-8 border-blue-600 space-y-6 animate-in slide-in-from-right-8 h-[750px] overflow-y-auto custom-scrollbar">
                    <div class="flex justify-between items-center border-b pb-4">
                        <h3 id="formTitle" class="text-xl font-black uppercase italic tracking-tighter">Carga de Proyecto</h3>
                        <button id="closeFormBtn" class="text-slate-300 hover:text-red-500"><i data-lucide="x"></i></button>
                    </div>
                    
                    <form id="projectForm" class="space-y-6">
                        <div class="space-y-1">
                            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Nombre del Proyecto</label>
                            <input type="text" id="projName" required placeholder="Nombre del proyecto" class="w-full bg-slate-50 border p-4 rounded-2xl font-bold text-sm outline-none focus:border-blue-600 transition-all">
                        </div>

                        <div id="concessionsContainer" class="space-y-4 pt-4">
                            <div class="flex justify-between items-center border-b pb-2">
                                <p class="text-[11px] font-black text-blue-600 uppercase tracking-widest italic">Concesiones</p>
                                <button type="button" id="addConcessionBtn" class="bg-blue-600 text-white p-1 rounded-lg hover:bg-blue-700 shadow-md">
                                    <i data-lucide="plus" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>

                        <button type="submit" class="w-full bg-[#1e293b] text-white py-5 rounded-[2.5rem] font-black text-xs uppercase tracking-widest shadow-xl hover:bg-black transition-all">
                            Guardar Información
                        </button>
                    </form>
                </div>

                <!-- Detalle -->
                <div id="detailPane" class="bg-white p-8 rounded-[3rem] shadow-2xl hidden animate-in zoom-in-95 h-[750px] flex flex-col">
                    <div class="flex justify-between items-start mb-6">
                        <span class="bg-blue-100 text-blue-700 px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest italic">Activo Minero</span>
                        <button id="closeDetailBtn" class="text-slate-200 hover:text-slate-400"><i data-lucide="x"></i></button>
                    </div>
                    <h2 id="detailTitle" class="text-3xl font-black text-slate-800 uppercase italic mb-8">Proyecto</h2>
                    
                    <div id="detailContent" class="flex-1 overflow-y-auto custom-scrollbar space-y-4 mb-6"></div>

                    <div class="flex gap-2">
                        <button id="editBtn" class="flex-1 bg-[#334155] text-white py-4 rounded-2xl font-black text-[10px] uppercase tracking-widest flex items-center justify-center gap-2">
                            <i data-lucide="edit-3" class="w-4 h-4"></i> Editar Datos
                        </button>
                        <button id="deleteBtn" class="w-14 bg-red-50 text-red-400 rounded-2xl flex items-center justify-center hover:bg-red-500 hover:text-white transition-all"><i data-lucide="trash-2" class="w-5 h-5"></i></button>
                    </div>
                </div>

                <!-- Inventario -->
                <div id="inventoryContainer" class="bg-white p-6 rounded-[2.5rem] shadow-sm border border-white">
                    <div class="flex justify-between items-center mb-4 px-2">
                        <h3 class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Base de Activos</h3>
                        <span id="activeCount" class="bg-slate-100 text-slate-500 text-[9px] font-black px-2 py-0.5 rounded-full">0 PROYECTOS</span>
                    </div>
                    <div id="projectsList" class="space-y-2 max-h-[300px] overflow-y-auto custom-scrollbar"></div>
                </div>
            </div>
        </main>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getFirestore, collection, addDoc, onSnapshot, query, doc, deleteDoc, setDoc, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";

        // CONFIGURACIÓN DE SEGURIDAD PARA EL ENTORNO
        const firebaseConfig = JSON.parse(window.__firebase_config || '{}');
        const appId = window.__app_id || 'enami-mining-dashboard';
        const initialToken = window.__initial_auth_token;

        // Validar si estamos en el entorno correcto
        if (!firebaseConfig.apiKey) {
            console.error("Firebase Config no detectada. Este archivo requiere el entorno de Canvas o una configuración válida para funcionar.");
        }

        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);

        let projects = [];
        let currentCoords = { x: 50, y: 50 };
        let currentUser = null;
        let selectedId = null;
        let isEditing = false;

        const MINERAL_OPTIONS = ["Titano Ferrosos", "Oro", "Plata", "Cobre", "Molibdeno", "Caliza"];

        lucide.createIcons();

        // Flujo de Autenticación Mandatorio
        const initAuth = async () => {
            try {
                if (initialToken) await signInWithCustomToken(auth, initialToken);
                else await signInAnonymously(auth);
            } catch (e) { console.error("Error de Autenticación", e); }
        };

        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                loadProjects();
                loadMapConfig();
            }
        });

        initAuth();

        function loadProjects() {
            if (!currentUser) return;
            const q = query(collection(db, 'artifacts', appId, 'public', 'data', 'projects'));
            onSnapshot(q, (snapshot) => {
                projects = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                updateKPIs();
                renderProjectsList();
                renderPins();
                if (selectedId) {
                    const p = projects.find(it => it.id === selectedId);
                    if (p) showDetail(p);
                }
            }, (error) => console.error("Error al cargar proyectos:", error));
        }

        function loadMapConfig() {
            if (!currentUser) return;
            const mapDoc = doc(db, 'artifacts', appId, 'public', 'data', 'map_config', 'main');
            onSnapshot(mapDoc, (snap) => {
                if (snap.exists() && snap.data().imageUrl) {
                    const img = document.getElementById('baseMapImg');
                    img.src = snap.data().imageUrl;
                    img.classList.remove('hidden');
                    document.getElementById('mapPlaceholder').classList.add('hidden');
                }
            });
        }

        window.addConcessionUI = function(data = null) {
            const container = document.getElementById('concessionsContainer');
            const div = document.createElement('div');
            div.className = "p-6 bg-slate-50 rounded-[2.5rem] border-2 border-slate-100 space-y-4 concession-block animate-fade-in";
            div.innerHTML = `
                <div class="flex justify-between items-center mb-2">
                    <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">Ficha Técnica</p>
                    <button type="button" class="remove-con-btn text-red-300 hover:text-red-500"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                </div>
                <input type="text" placeholder="Concesión / Área" class="w-full bg-white border p-3 rounded-xl font-bold text-xs outline-none focus:border-blue-500" required value="${data?.name || ''}">
                <div class="grid grid-cols-2 gap-2">
                    <input type="text" placeholder="Cód. Catastral" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.cadastralCode || ''}">
                    <input type="text" placeholder="Tipo Minería" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.miningType || ''}">
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <input type="text" placeholder="Hectáreas" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.surface || ''}">
                    <input type="text" placeholder="Régimen" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.regime || ''}">
                </div>
                <input type="text" placeholder="Periodo" class="w-full bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.period || ''}">
                
                <div class="pt-2 border-t border-slate-200">
                    <p class="text-[9px] font-black text-slate-400 uppercase mb-2 tracking-widest italic">Ubicación</p>
                    <input type="text" placeholder="Provincia" class="w-full bg-white border p-2 rounded-xl text-[10px] outline-none mb-2" value="${data?.province || ''}">
                    <div class="grid grid-cols-2 gap-2">
                        <input type="text" placeholder="Cantón" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.canton || ''}">
                        <input type="text" placeholder="Parroquia" class="bg-white border p-2 rounded-xl text-[10px] outline-none" value="${data?.parish || ''}">
                    </div>
                </div>

                <div class="pt-2 border-t border-slate-200">
                    <div class="flex justify-between items-center mb-2">
                        <p class="text-[9px] font-black text-slate-400 uppercase tracking-widest">Minerales</p>
                        <button type="button" class="add-mineral-btn bg-blue-100 text-blue-600 p-1 rounded-lg hover:bg-blue-200 transition-all"><i data-lucide="plus" class="w-3 h-3"></i></button>
                    </div>
                    <div class="minerals-list space-y-2"></div>
                </div>
            `;
            container.appendChild(div);
            lucide.createIcons();

            div.querySelector('.remove-con-btn').onclick = () => div.remove();
            const minList = div.querySelector('.minerals-list');
            div.querySelector('.add-mineral-btn').onclick = () => addMineralRowUI(minList);
            
            if (data?.minerals && Array.isArray(data.minerals)) {
                data.minerals.forEach(m => addMineralRowUI(minList, m));
            } else {
                addMineralRowUI(minList);
            }
        };

        function addMineralRowUI(container, val = '') {
            const div = document.createElement('div');
            div.className = "flex gap-2 animate-fade-in";
            div.innerHTML = `
                <select class="flex-1 bg-white border p-2 rounded-xl text-[10px] font-black outline-none cursor-pointer focus:border-blue-500">
                    ${MINERAL_OPTIONS.map(opt => `<option value="${opt}" ${opt === val ? 'selected' : ''}>${opt}</option>`).join('')}
                </select>
                <button type="button" class="text-slate-300 hover:text-red-500"><i data-lucide="x" class="w-4 h-4"></i></button>
            `;
            container.appendChild(div);
            lucide.createIcons();
            div.querySelector('button').onclick = () => div.remove();
        }

        function updateKPIs() {
            const totalCons = projects.reduce((acc, p) => acc + (p.concessions?.length || 0), 0);
            document.getElementById('kpiConcessions').textContent = totalCons;
            document.getElementById('activeCount').textContent = `${projects.length} PROYECTOS`;
        }

        function renderPins() {
            const overlay = document.getElementById('pinsOverlay');
            overlay.innerHTML = '';
            projects.forEach(p => {
                const pin = document.createElement('div');
                const isSelected = selectedId === p.id;
                pin.className = `absolute w-6 h-6 -ml-3 -mt-3 rounded-full border-4 border-white shadow-xl transition-all duration-300 cursor-pointer ${isSelected ? 'bg-orange-500 scale-125 z-20 ring-4 ring-orange-100' : 'bg-blue-600 z-10 hover:scale-110'}`;
                pin.style.left = `${p.x}%`;
                pin.style.top = `${p.y}%`;
                pin.onclick = (e) => { e.stopPropagation(); showDetail(p); };
                overlay.appendChild(pin);
            });

            if (!document.getElementById('formSection').classList.contains('hidden')) {
                const ghost = document.createElement('div');
                ghost.className = "absolute w-8 h-8 -ml-4 -mt-4 bg-blue-600 border-4 border-white rounded-full shadow-2xl animate-bounce flex items-center justify-center";
                ghost.style.left = `${currentCoords.x}%`;
                ghost.style.top = `${currentCoords.y}%`;
                overlay.appendChild(ghost);
            }
        }

        function renderProjectsList() {
            const list = document.getElementById('projectsList');
            list.innerHTML = projects.length === 0 ? '<p class="text-center py-10 text-slate-300 text-[10px] font-black uppercase tracking-widest">Sin registros</p>' : '';
            projects.forEach(p => {
                const div = document.createElement('div');
                div.className = `p-4 rounded-2xl cursor-pointer flex justify-between items-center transition-all ${selectedId === p.id ? 'bg-blue-50 border-blue-200 border-2' : 'bg-slate-50 border-transparent border-2 hover:bg-slate-100'}`;
                div.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="w-2 h-2 rounded-full bg-blue-600"></div>
                        <div>
                            <p class="font-black text-xs uppercase italic">${p.name}</p>
                            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-tighter">${p.concessions?.length || 0} Concesiones</p>
                        </div>
                    </div>
                `;
                div.onclick = () => showDetail(p);
                list.appendChild(div);
            });
            lucide.createIcons();
        }

        function showDetail(p) {
            selectedId = p.id;
            document.getElementById('detailPane').classList.remove('hidden');
            document.getElementById('formSection').classList.add('hidden');
            document.getElementById('inventoryContainer').classList.add('hidden');
            document.getElementById('clickLayer').classList.add('hidden');
            document.getElementById('detailTitle').textContent = p.name;
            
            const content = document.getElementById('detailContent');
            content.innerHTML = '';
            (p.concessions || []).forEach((con, idx) => {
                const div = document.createElement('div');
                div.className = "bg-slate-50 p-6 rounded-[2.5rem] border border-slate-100 mb-4 shadow-sm";
                div.innerHTML = `
                    <p class="text-[10px] font-black text-blue-600 uppercase italic mb-3 border-b pb-2 tracking-widest">Concesión: ${con.name}</p>
                    <div class="grid grid-cols-2 gap-4 text-[10px]">
                        <div><p class="text-slate-400 uppercase font-bold text-[8px]">Catastro</p><p class="font-black italic">${con.cadastralCode || 'N/A'}</p></div>
                        <div><p class="text-slate-400 uppercase font-bold text-[8px]">Superficie</p><p class="font-black italic">${con.surface || '0'} Ha</p></div>
                        <div class="col-span-2"><p class="text-slate-400 uppercase font-bold text-[8px]">Localización</p><p class="font-black italic">${con.province || '-'} / ${con.canton || '-'}</p></div>
                        <div class="col-span-2"><p class="text-slate-400 uppercase font-bold text-[8px]">Recursos</p><p class="font-black text-blue-600">${con.minerals?.join(', ') || '---'}</p></div>
                    </div>
                `;
                content.appendChild(div);
            });

            renderPins();
            renderProjectsList();
        }

        document.getElementById('newProjectBtn').onclick = () => {
            isEditing = false;
            selectedId = null;
            document.getElementById('formSection').classList.remove('hidden');
            document.getElementById('detailPane').classList.add('hidden');
            document.getElementById('clickLayer').classList.remove('hidden');
            document.getElementById('inventoryContainer').classList.add('hidden');
            document.getElementById('formTitle').textContent = "Nuevo Proyecto";
            document.getElementById('projName').value = "";
            document.getElementById('concessionsContainer').innerHTML = '';
            window.addConcessionUI();
            renderPins();
        };

        document.getElementById('editBtn').onclick = () => {
            const p = projects.find(it => it.id === selectedId);
            if (!p) return;
            isEditing = true;
            document.getElementById('formSection').classList.remove('hidden');
            document.getElementById('detailPane').classList.add('hidden');
            document.getElementById('clickLayer').classList.remove('hidden');
            document.getElementById('formTitle').textContent = "Editar Proyecto";
            document.getElementById('projName').value = p.name;
            currentCoords = { x: p.x, y: p.y };
            document.getElementById('concessionsContainer').innerHTML = '';
            p.concessions.forEach(c => window.addConcessionUI(c));
            renderPins();
        };

        document.getElementById('projectForm').onsubmit = async (e) => {
            e.preventDefault();
            if (!currentUser) return;

            const conBlocks = document.querySelectorAll('.concession-block');
            const concessions = Array.from(conBlocks).map(b => {
                const inputs = b.querySelectorAll('input');
                const minerals = Array.from(b.querySelectorAll('select')).map(s => s.value);
                return {
                    name: inputs[0].value, cadastralCode: inputs[1].value,
                    miningType: inputs[2].value, surface: inputs[3].value,
                    regime: inputs[4].value, period: inputs[5].value,
                    province: inputs[6].value, canton: inputs[7].value,
                    parish: inputs[8].value, minerals
                };
            });

            const data = {
                name: document.getElementById('projName').value,
                x: currentCoords.x, y: currentCoords.y, concessions
            };

            try {
                if (isEditing && selectedId) {
                    await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', selectedId), data);
                } else {
                    await addDoc(collection(db, 'artifacts', appId, 'public', 'data', 'projects'), data);
                }
                
                document.getElementById('formSection').classList.add('hidden');
                document.getElementById('inventoryContainer').classList.remove('hidden');
                document.getElementById('clickLayer').classList.add('hidden');
                isEditing = false;
            } catch (err) {
                console.error("Error al guardar:", err);
            }
        };

        // Escuchar clics en el mapa para ubicar puntos
        document.getElementById('clickLayer').onclick = (e) => {
            const rect = document.getElementById('mapContainer').getBoundingClientRect();
            currentCoords.x = ((e.clientX - rect.left) / rect.width) * 100;
            currentCoords.y = ((e.clientY - rect.top) / rect.height) * 100;
            renderPins();
        };

        document.getElementById('mapUpload').addEventListener('change', async (e) => {
            const file = e.target.files[0];
            if (!file || !currentUser) return;
            if (file.size > 1000000) { alert("Archivo muy pesado (>1MB)."); return; }
            const reader = new FileReader();
            reader.onload = async (f) => {
                await setDoc(doc(db, 'artifacts', appId, 'public', 'data', 'map_config', 'main'), { imageUrl: f.target.result });
            };
            reader.readAsDataURL(file);
        });

        document.getElementById('closeFormBtn').onclick = () => {
            document.getElementById('formSection').classList.add('hidden');
            document.getElementById('inventoryContainer').classList.remove('hidden');
            document.getElementById('clickLayer').classList.add('hidden');
            renderPins();
        };

        document.getElementById('closeDetailBtn').onclick = () => {
            selectedId = null;
            document.getElementById('detailPane').classList.add('hidden');
            document.getElementById('inventoryContainer').classList.remove('hidden');
            renderPins();
        };

        document.getElementById('deleteBtn').onclick = async () => {
            if (!selectedId) return;
            if (confirm("¿Eliminar proyecto permanentemente?")) {
                await deleteDoc(doc(db, 'artifacts', appId, 'public', 'data', 'projects', selectedId));
                selectedId = null;
                document.getElementById('detailPane').classList.add('hidden');
                document.getElementById('inventoryContainer').classList.remove('hidden');
            }
        };

        document.getElementById('addConcessionBtn').onclick = () => window.addConcessionUI();
    </script>
</body>
</html>
